let zz;window.onload=()=>{let t=window.data,e=`<style>html,body{width:100%;height:100%;margin:0;}svg{width:97%;height:97%;margin:0;}</style><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 560"><style>.i{font-family:AreaNormal-ExtraBold}.n{font-size:17px}.q{font-size:16px;font-style:italic}.pxl{image-rendering:pixelated}</style><rect fill="${t.bBg}" x="10" y="10" width="380" height="540" rx="15" />${t.bSvg}<rect stroke="black" stroke-width="19" fill="none" x="0" y="10" width="400" height="540" rx="15" /><rect fill="${t.mBg}" x="65" y="70" width="270" height="270" /><rect x="60" y="70" width="280" height="270" class="f"/>${t.mImg?'<image class="pxl" href="/s/'+t.mImg+'" x="65" y="70" height="270" width="270" />':""}<rect x="38" y="347" width="324" height="177" class="f"/><path d="M42 347h316v172H42z" fill="${t.txtBg}"/><rect rx="10" x="29.5" y="334" width="340" height="40" class="f"/><rect fill="${t.titleBg}" rx="8" x="35" y="339" width="330" height="30" />${t.stats?` <rect rx="10" x="300" y="495" width="70" height="40" class="f"/><rect fill="${t.titleBg}" rx="8" x="304" y="499" width="62" height="32" />`:""}<rect rx="10" x="26" y="34" width="348" height="44" class="f"/><rect fill="${t.titleBg}" rx="8" x="32" y="40" width="336" height="32" /><text class="i" font-size="28" x="40" y="64">${t.top}</text>${t.mana}<text class="i" font-size="20" x="40" y="360">${t.mid}</text><text y="396" transform="translate(53)"><tspan x="0" class="i n" text-anchor="left">${t.botT[0]}</tspan><tspan x="0" class="i n" text-anchor="left" dy="17">${t.botT[1]}</tspan><tspan x="0" class="i n" text-anchor="left" dy="17">${t.botT[2]}</tspan><tspan x="0" class="i n" text-anchor="left" dy="17">${t.botT[3]}</tspan><tspan x="0" class="i q" text-anchor="left" dy="16">${t.botQ[0]}</tspan><tspan x="0" class="i q" text-anchor="left" dy="16">${t.botQ[1]}</tspan><tspan x="0" class="i q" text-anchor="left" dy="16">${t.botQ[2]}</tspan><tspan x="0" class="i q" text-anchor="left" dy="16">${t.botQ[3]}</tspan><tspan x="0" class="i q" text-anchor="left" dy="26">${t.botC}</tspan></text>${t.stats?` <text y="522" transform="translate(335)"><tspan x="0" class="i" font-size="24" text-anchor="middle">${t.stats}</tspan></text>`:""}</svg>\n`;document.body.innerHTML=e};