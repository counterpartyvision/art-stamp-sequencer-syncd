function detectOsBrowser(){var userAgent=navigator.userAgent;var finalOs="";var finalBrowser="";if(userAgent.indexOf('Windows')!==-1){finalOs="Windows"}else if(userAgent.indexOf('Mac')!==-1){finalOs="osX"}else if(userAgent.indexOf('Linux')!==-1){finalOs="Linux"}else if(userAgent.indexOf('iPhone')!==-1||userAgent.indexOf('iPad')!==-1){finalOs="iOS"}else if(userAgent.indexOf('Android')!==-1){finalOs="Android"}else if(userAgent.indexOf('CrOS')!==-1){finalOs="ChromeOS"}
if(userAgent.indexOf('Edg')!==-1){finalBrowser="Edge"}else if(userAgent.indexOf('Brave')!==-1){finalBrowser="Brave"}else if(userAgent.indexOf('Chrome')!==-1&&userAgent.indexOf('Edg')===-1&&userAgent.indexOf('Brave')===-1){finalBrowser="Chrome"}else if(userAgent.indexOf('Opera')!==-1||userAgent.indexOf('OPR')!==-1){finalBrowser="Opera"}else if(userAgent.indexOf('Safari')!==-1&&userAgent.indexOf('Chrome')===-1){finalBrowser="Safari"}else if(userAgent.indexOf('Firefox')!==-1){finalBrowser="Firefox"}else if(userAgent.indexOf('MSIE')!==-1||userAgent.indexOf('Trident')!==-1){finalBrowser="IE"}
var rootElement=document.documentElement;if(finalOs){rootElement.classList.add(finalOs)}
if(finalBrowser){rootElement.classList.add(finalBrowser)}}
detectOsBrowser()